<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.qdc.lims.ui.controller.CancelledOrdersReportController"
            prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #f5f6fa;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #2c3e50; -fx-padding: 15 20;">
            <Label text="Cancelled Orders Report" textFill="WHITE">
                <font>
                    <Font name="System Bold" size="20.0"/>
                </font>
            </Label>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="closeButton" text="Close" onAction="#handleClose" styleClass="admin-close-button"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="20.0">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <HBox spacing="15.0" alignment="CENTER_LEFT"
                  style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 5; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
                <Label text="From:"/>
                <DatePicker fx:id="startDatePicker" prefWidth="150"/>
                <Label text="To:"/>
                <DatePicker fx:id="endDatePicker" prefWidth="150"/>
                <Button text="Today" onAction="#handleQuickToday" style="-fx-background-color: #ecf0f1;"/>
                <Button text="7 Days" onAction="#handleQuickWeek" style="-fx-background-color: #ecf0f1;"/>
                <Button text="This Month" onAction="#handleQuickMonth" style="-fx-background-color: #ecf0f1;"/>
                <Button text="Generate Report" onAction="#handleGenerateReport"
                        style="-fx-background-color: #c0392b; -fx-text-fill: white;"/>
            </HBox>

            <VBox spacing="10">
                <Label fx:id="periodLabel" text="Select a date range to generate cancelled order report."
                       style="-fx-text-fill: #7f8c8d;"/>
                <HBox spacing="15">
                    <VBox spacing="4" alignment="CENTER"
                          style="-fx-background-color: white; -fx-padding: 12; -fx-background-radius: 6; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 4, 0, 0, 1);"
                          HBox.hgrow="ALWAYS">
                        <Label text="Cancelled Orders" textFill="#7f8c8d"/>
                        <Label fx:id="cancelledCountLabel" text="0"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #c0392b;"/>
                    </VBox>
                    <VBox spacing="4" alignment="CENTER"
                          style="-fx-background-color: white; -fx-padding: 12; -fx-background-radius: 6; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 4, 0, 0, 1);"
                          HBox.hgrow="ALWAYS">
                        <Label text="Total Refund Amount" textFill="#7f8c8d"/>
                        <Label fx:id="totalRefundLabel" text="0.00"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2980b9;"/>
                    </VBox>
                </HBox>
            </VBox>

            <VBox fx:id="emptyStateBox" spacing="8" alignment="CENTER"
                  style="-fx-background-color: white; -fx-padding: 24; -fx-background-radius: 6; -fx-border-color: #ecf0f1;">
                <Label text="No report loaded yet." style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                <Label text="Select a date range and click Generate Report to view cancelled orders."
                       style="-fx-text-fill: #7f8c8d;"/>
            </VBox>

            <VBox fx:id="detailsBox" VBox.vgrow="ALWAYS" visible="false" managed="false">
                <Label text="Cancelled Orders Details" style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
                <TableView fx:id="cancelledOrdersTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="orderIdCol" text="Order ID" prefWidth="90"/>
                        <TableColumn fx:id="patientCol" text="Patient" prefWidth="200"/>
                        <TableColumn fx:id="cancelledAtCol" text="Cancelled At" prefWidth="170"/>
                        <TableColumn fx:id="cancelledByCol" text="Cancelled By" prefWidth="130"/>
                        <TableColumn fx:id="refundCol" text="Refund" prefWidth="120"/>
                        <TableColumn fx:id="reasonCol" text="Reason" prefWidth="300"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>
        </VBox>
    </center>

</BorderPane>

